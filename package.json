{
  "name": "claude-skills-for-copilot",
  "displayName": "Claude Skills for Copilot",
  "description": "GitHub Copilot agent skills adapted from the official Claude plugins: code-review, code-simplifier, and more.",
  "version": "0.0.5",
  "publisher": "euxx",
  "engines": {
    "vscode": "^1.95.0"
  },
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/euxx/claude-skills-for-copilot"
  },
  "categories": [
    "AI"
  ],
  "scripts": {
    "vscode:prepublish": "npm run ci",
    "package": "npx @vscode/vsce package --no-dependencies",
    "format": "prettier --write \"**/*.md\"",
    "format:check": "prettier --check \"**/*.md\"",
    "ci": "npm run format:check",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.0.0"
  },
  "lint-staged": {
    "*.md": [
      "prettier --write --prose-wrap preserve"
    ]
  },
  "contributes": {
    "chatSkills": [
      { "path": "./skills/code-review/SKILL.md" },
      { "path": "./skills/code-simplifier/SKILL.md" },
      { "path": "./skills/comment-analyzer/SKILL.md" },
      { "path": "./skills/feature-dev/SKILL.md" },
      { "path": "./skills/frontend-design/SKILL.md" },
      { "path": "./skills/review-toolkit/SKILL.md" },
      { "path": "./skills/silent-failure-hunter/SKILL.md" },
      { "path": "./skills/test-analyzer/SKILL.md" },
      { "path": "./skills/type-design-analyzer/SKILL.md" }
    ]
  }
}
