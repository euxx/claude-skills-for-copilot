{
  "name": "claude-skills-for-copilot",
  "displayName": "Claude Skills for Copilot",
  "version": "0.4.1",
  "description": "GitHub Copilot agent skills adapted from Anthropic Claude plugins and OpenAI Codex Skills.",
  "categories": [
    "AI"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/euxx/claude-skills-for-copilot"
  },
  "publisher": "euxx",
  "scripts": {
    "vscode:prepublish": "npm run ci",
    "ci": "npm run lint && npm run format:check && npm run test",
    "test": "echo 'No tests'  && exit 0",
    "lint": "echo 'No lint'  && exit 0",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "package": "npx @vscode/vsce package --no-dependencies",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "latest",
    "lint-staged": "latest",
    "oxfmt": "latest"
  },
  "lint-staged": {
    "*.{md,yml,yaml,json}": [
      "oxfmt --write"
    ]
  },
  "contributes": {
    "chatSkills": [
      {
        "path": "./skills/code-review/SKILL.md"
      },
      {
        "path": "./skills/code-simplifier/SKILL.md"
      },
      {
        "path": "./skills/comment-analyzer/SKILL.md"
      },
      {
        "path": "./skills/conventions-improver/SKILL.md"
      },
      {
        "path": "./skills/feature-dev/SKILL.md"
      },
      {
        "path": "./skills/frontend-design/SKILL.md"
      },
      {
        "path": "./skills/frontend-layout/SKILL.md"
      },
      {
        "path": "./skills/gh-address-comments/SKILL.md"
      },
      {
        "path": "./skills/gh-fix-ci/SKILL.md"
      },
      {
        "path": "./skills/mcp-server-dev/SKILL.md"
      },
      {
        "path": "./skills/review-toolkit/SKILL.md"
      },
      {
        "path": "./skills/security-threat-model/SKILL.md"
      },
      {
        "path": "./skills/silent-failure-hunter/SKILL.md"
      },
      {
        "path": "./skills/test-analyzer/SKILL.md"
      },
      {
        "path": "./skills/type-design-analyzer/SKILL.md"
      }
    ]
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.95.0"
  }
}
